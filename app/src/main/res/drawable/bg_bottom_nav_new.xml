<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Subtle top border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F0F0F0"/>
        </shape>
    </item>
    <!-- White background -->
    <item android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
</layer-list>
