<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Darkened Backdrop -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>

    <!-- CARD -->
    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_subscription"
        android:elevation="8dp">

        <!-- BEE LOGO -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_bee"
                android:contentDescription="Bee Logo"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subscription"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#000000"/>
        </LinearLayout>


        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go avail Sensors for monitoring hives"
            android:textStyle="bold"
            android:textSize="18sp"
            android:gravity="center"
            android:paddingTop="8dp"
            android:textColor="#000000"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apiaries Available:"
            android:gravity="center"
            android:paddingTop="6dp"
            android:textColor="#000000"/>

        <!-- PLANS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:paddingTop="10dp">

            <!-- 1-2 -->
            <LinearLayout
                android:id="@+id/plan1Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1-2"
                    android:textColor="@android:color/white"
                    android:background="@android:color/black"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="P550.00\n3 months"
                    android:gravity="center"
                    android:background="#FFECB3"
                    android:padding="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="P183.00\nmonthly"
                    android:gravity="center"
                    android:background="#FFD54F"
                    android:padding="6dp"/>
            </LinearLayout>

            <!-- 3-5 -->
            <LinearLayout
                android:id="@+id/plan2Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3-5"
                    android:textColor="@android:color/white"
                    android:background="@android:color/black"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="P750.00\n3 months"
                    android:gravity="center"
                    android:background="#FFECB3"
                    android:padding="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="P250.00\nmonthly"
                    android:gravity="center"
                    android:background="#FFD54F"
                    android:padding="6dp"/>
            </LinearLayout>

            <!-- 5+ -->
            <LinearLayout
                android:id="@+id/plan3Container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="5+"
                    android:textColor="@android:color/white"
                    android:background="@android:color/black"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:padding="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="P999.00\n3 months"
                    android:gravity="center"
                    android:background="#FFECB3"
                    android:padding="6dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="P333.00\nmonthly"
                    android:gravity="center"
                    android:background="#FFD54F"
                    android:padding="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sensors are used for monitoring its temperature, humidity, weight, and time harvesting for each hive."
            android:textSize="12sp"
            android:gravity="center"
            android:paddingTop="10dp"
            android:textColor="#000000"/>

        <!-- Dismiss -->
        <TextView
            android:id="@+id/btnDismiss"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dismiss"
            android:layout_gravity="center"
            android:paddingTop="14dp"
            android:textColor="#000000"/>
    </LinearLayout>
</FrameLayout>
