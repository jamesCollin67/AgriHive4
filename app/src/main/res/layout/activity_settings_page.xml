<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#000000" />

    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <View
        android:id="@+id/headerDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#EEEEEE"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/footerNav"
        app:layout_constraintTop_toBottomOf="@id/headerDivider">

        <LinearLayout
            android:id="@+id/settingsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/rowNotifications"
                style="@style/SettingsRowStyle">
                <ImageView
                    android:id="@+id/iconNotifications"
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_notifications" />
                <TextView
                    android:id="@+id/tvNotifications"
                    style="@style/SettingsTextStyle"
                    android:text="Notifications" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:trackTint="#4CAF50" />
            </LinearLayout>
            <View
                android:id="@+id/dividerNotifications"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:id="@+id/rowDeviceControls"
                style="@style/SettingsRowStyle">
                <ImageView
                    android:id="@+id/iconDeviceControls"
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_phone" />
                <TextView
                    android:id="@+id/tvDeviceControls"
                    style="@style/SettingsTextStyle"
                    android:text="Device Controls" />
                <ImageView
                    android:id="@+id/chevronDeviceControls"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FFB74D" />
            </LinearLayout>
            <View
                android:id="@+id/dividerDeviceControls"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:id="@+id/rowCloudSync"
                style="@style/SettingsRowStyle">
                <ImageView
                    android:id="@+id/iconCloudSync"
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_cloud" />
                <TextView
                    android:id="@+id/tvCloudSync"
                    style="@style/SettingsTextStyle"
                    android:text="Cloud Sync" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchCloudSync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:trackTint="#4CAF50" />
            </LinearLayout>
            <View
                android:id="@+id/dividerCloudSync"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:id="@+id/rowActivityLog"
                style="@style/SettingsRowStyle">
                <ImageView
                    android:id="@+id/iconActivityLog"
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_activity" />
                <TextView
                    android:id="@+id/tvActivityLog"
                    style="@style/SettingsTextStyle"
                    android:text="Activity log" />
                <ImageView
                    android:id="@+id/chevronActivityLog"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FFB74D" />
            </LinearLayout>
            <View
                android:id="@+id/dividerActivityLog"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:id="@+id/rowChangePassword"
                style="@style/SettingsRowStyle">
                <ImageView
                    android:id="@+id/iconChangePassword"
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_lock" />
                <TextView
                    android:id="@+id/tvChangePassword"
                    style="@style/SettingsTextStyle"
                    android:text="Change password" />
                <ImageView
                    android:id="@+id/chevronChangePassword"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FFB74D" />
            </LinearLayout>
            <View
                android:id="@+id/dividerChangePassword"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:id="@+id/rowSavedTreatments"
                style="@style/SettingsRowStyle">
                <ImageView
                    android:id="@+id/iconSavedTreatments"
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_saved" />
                <TextView
                    android:id="@+id/tvSavedTreatments"
                    style="@style/SettingsTextStyle"
                    android:text="Saved Treatments" />
                <ImageView
                    android:id="@+id/chevronSavedTreatments"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FFB74D" />
            </LinearLayout>
            <View
                android:id="@+id/dividerSavedTreatments"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:id="@+id/rowSubscription"
                style="@style/SettingsRowStyle">
                <ImageView
                    android:id="@+id/iconSubscription"
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_bee" />
                <TextView
                    android:id="@+id/tvSubscription"
                    style="@style/SettingsTextStyle"
                    android:text="Subscription" />
                <ImageView
                    android:id="@+id/chevronSubscription"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FFB74D" />
            </LinearLayout>
            <View
                android:id="@+id/dividerSubscription"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:id="@+id/rowLogout"
                style="@style/SettingsRowStyle">
                <ImageView
                    android:id="@+id/iconLogout"
                    style="@style/SettingsIconStyle"
                    android:src="@drawable/ic_logout" />
                <TextView
                    android:id="@+id/tvLogout"
                    style="@style/SettingsTextStyle"
                    android:text="Logout" />
                <ImageView
                    android:id="@+id/chevronLogout"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="#FFB74D" />
            </LinearLayout>
            <View
                android:id="@+id/dividerLogout"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/footerNav"
        layout="@layout/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
