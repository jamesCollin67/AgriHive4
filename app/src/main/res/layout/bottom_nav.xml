<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false">

    <!-- iOS-style Swipe Indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_swipe_indicator"
        android:clipChildren="false"/>

    <!-- Navigation Items with White Background -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:clipChildren="false">

        <!-- Home (Active - Yellow) -->
        <LinearLayout
            android:id="@+id/navHomeContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/navHome"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="@color/nav_active" />

            <TextView
                android:id="@+id/tvHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="11sp"
                android:textColor="@color/nav_active"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- History (Gray) -->
        <LinearLayout
            android:id="@+id/navSearchContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/navSearch"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/nav_inactive" />

            <TextView
                android:id="@+id/tvSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="History"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Center Space for FAB -->
        <View
            android:layout_width="56dp"
            android:layout_height="56dp"/>

        <!-- Profile (Gray) -->
        <LinearLayout
            android:id="@+id/navProfileContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/navProfile"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/nav_inactive" />

            <TextView
                android:id="@+id/tvProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Settings (Gray) -->
        <LinearLayout
            android:id="@+id/navHistoryContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <ImageView
                android:id="@+id/navHistory"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_settings"
                app:tint="@color/nav_inactive" />

            <TextView
                android:id="@+id/tvHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Centered FAB (Camera) - Floating above the nav bar -->
    <FrameLayout
        android:id="@+id/navScanContainer"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal|bottom"
        android:elevation="12dp"
        android:background="@drawable/bg_fab_yellow"
        android:clickable="true"
        android:focusable="true"
        android:clipToOutline="false"
        android:layout_marginBottom="28dp">

        <ImageView
            android:id="@+id/navScan"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_camera"
            app:tint="#FFFFFF"/>

    </FrameLayout>

</FrameLayout>
