<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1815"
    android:fillViewport="true"
    tools:context=".settings.ChangePasswordActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="40dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Password"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack" />

        <!-- Shield Header -->
        <View
            android:id="@+id/viewShieldBorder"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_shield_circle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvToolbarTitle" />

        <ImageView
            android:id="@+id/ivShield"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_shield_outline"
            app:layout_constraintBottom_toBottomOf="@id/viewShieldBorder"
            app:layout_constraintEnd_toEndOf="@id/viewShieldBorder"
            app:layout_constraintStart_toStartOf="@id/viewShieldBorder"
            app:layout_constraintTop_toTopOf="@id/viewShieldBorder"
            app:tint="#F4B400" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:text="Choose a strong password that you haven't used before and includes a mix of letters and numbers"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/viewShieldBorder" />

        <!-- Current Password Section -->
        <TextView
            android:id="@+id/labelCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Current Password"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

        <FrameLayout
            android:id="@+id/boxCurrent"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_password_input"
            app:layout_constraintTop_toBottomOf="@id/labelCurrent">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock"
                app:tint="#9CAF9F" />

            <EditText
                android:id="@+id/etCurrentPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="52dp"
                android:layout_marginEnd="48dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:hint="● ● ● ● ● ● ● ●"
                android:inputType="textPassword"
                android:textColor="#9CAF9F"
                android:textColorHint="#9CAF9F"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ivToggleCurrent"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye"
                app:tint="#9CAF9F" />
        </FrameLayout>

        <!-- New Password Section -->
        <TextView
            android:id="@+id/labelNew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:text="New Password"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/boxCurrent" />

        <FrameLayout
            android:id="@+id/boxNew"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_password_input"
            app:layout_constraintTop_toBottomOf="@id/labelNew">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock"
                app:tint="#9CAF9F" />

            <EditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="52dp"
                android:layout_marginEnd="48dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:hint="● ● ● ● ● ● ● ●"
                android:inputType="textPassword"
                android:textColor="#9CAF9F"
                android:textColorHint="#9CAF9F"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ivToggleNew"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye"
                app:tint="#9CAF9F" />
        </FrameLayout>

        <!-- Confirm Password Section -->
        <TextView
            android:id="@+id/labelConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:text="Confirm New Password"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/boxNew" />

        <FrameLayout
            android:id="@+id/boxConfirm"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_password_input"
            app:layout_constraintTop_toBottomOf="@id/labelConfirm">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock"
                app:tint="#9CAF9F" />

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="52dp"
                android:layout_marginEnd="48dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:hint="● ● ● ● ● ● ● ●"
                android:inputType="textPassword"
                android:textColor="#9CAF9F"
                android:textColorHint="#9CAF9F"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ivToggleConfirm"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye"
                app:tint="#9CAF9F" />
        </FrameLayout>

        <!-- Update Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdate"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/bg_button_gradient"
            app:backgroundTint="@null"
            android:text="Update Password"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_check_small"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="24dp"
            app:iconTint="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/boxConfirm" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
