<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F241F"
    android:paddingHorizontal="24dp">

    <!-- Success Icon -->
    <FrameLayout
        android:id="@+id/layout_success_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/bg_green_circle"
        android:backgroundTint="#1A3329"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check_white"
            app:tint="#66BB6A" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_success_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="sans-serif-black"
        android:text="Report Sent Successfully!"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_success_icon" />

    <TextView
        android:id="@+id/tv_success_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Your report has been submitted. Our team will review the issue and get back to you shortly."
        android:textColor="#9CAF9F"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/tv_success_title" />

    <!-- Receipt/Summary Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_report_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="#1A3329"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tv_success_subtitle"
        app:strokeColor="#2D4A3E"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="#F4B400" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="sans-serif-black"
                    android:text="Report Details"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- Details -->
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ticket ID" android:textColor="#9CAF9F" android:textSize="13sp" />
                <TextView android:id="@+id/tv_ticket_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="RPT-98214432" android:textColor="#FFFFFF" android:textSize="13sp" />
            </RelativeLayout>

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Type" android:textColor="#9CAF9F" android:textSize="13sp" />
                <TextView android:id="@+id/tv_report_type" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="Hive Issue" android:textColor="#FFFFFF" android:textSize="13sp" />
            </RelativeLayout>

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Apiary" android:textColor="#9CAF9F" android:textSize="13sp" />
                <TextView android:id="@+id/tv_report_apiary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="Main Farm Apiary" android:textColor="#FFFFFF" android:textSize="13sp" />
            </RelativeLayout>

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date Submitted" android:textColor="#9CAF9F" android:textSize="13sp" />
                <TextView android:id="@+id/tv_report_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="March 24, 2026" android:textColor="#FFFFFF" android:textSize="13sp" />
            </RelativeLayout>

            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status" android:textColor="#9CAF9F" android:textSize="13sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-black" android:text="SUBMITTED" android:textColor="#66BB6A" android:textSize="13sp" />
            </RelativeLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Confirmation Info (Blue card as seen in payment successful image) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_confirmation_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#142B33"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/card_report_summary"
        app:strokeColor="#1B3A44"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_phone"
                app:tint="#2196F3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="A confirmation email has been sent to your registered account."
                android:textColor="#9CAF9F"
                android:textSize="13sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back_dashboard"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="40dp"
        android:backgroundTint="#F4B400"
        android:fontFamily="sans-serif-black"
        android:text="Back to Dashboard"
        android:textAllCaps="false"
        android:textColor="#0F241F"
        android:textSize="18sp"
        app:cornerRadius="18dp"
        app:icon="@drawable/ic_home"
        app:iconGravity="textStart"
        app:iconTint="#0F241F"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
