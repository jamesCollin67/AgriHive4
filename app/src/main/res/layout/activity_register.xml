<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1815"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Go back"
            android:src="@drawable/ic_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="sans-serif-black"
            android:text="Create Account"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_back" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Join the colony and start monitoring"
            android:textColor="#9CAF9F"
            android:textSize="15sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <!-- Name Row Labels -->
        <TextView
            android:id="@+id/label_first_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="First Name"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/label_last_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

        <TextView
            android:id="@+id/label_last_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Last Name"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/label_first_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/label_first_name" />

        <!-- Name Inputs -->
        <FrameLayout
            android:id="@+id/box_first_name"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_password_input"
            app:layout_constraintEnd_toStartOf="@+id/box_last_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/label_first_name">

            <EditText
                android:id="@+id/firstName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="16dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:hint="First"
                android:inputType="textPersonName"
                android:textColor="#FFFFFF"
                android:textColorHint="#9CAF9F"
                android:textSize="16sp" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/box_last_name"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_password_input"
            app:layout_constraintBottom_toBottomOf="@+id/box_first_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/box_first_name">

            <EditText
                android:id="@+id/lastName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="16dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:hint="Last"
                android:inputType="textPersonName"
                android:textColor="#FFFFFF"
                android:textColorHint="#9CAF9F"
                android:textSize="16sp" />
        </FrameLayout>

        <!-- Email field -->
        <TextView
            android:id="@+id/label_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Email Address"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/box_first_name" />

        <FrameLayout
            android:id="@+id/box_email"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_password_input"
            app:layout_constraintTop_toBottomOf="@id/label_email">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_envelope"
                app:tint="#9CAF9F" />

            <EditText
                android:id="@+id/email"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="52dp"
                android:layout_marginEnd="16dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:textColor="#FFFFFF"
                android:textColorHint="#9CAF9F"
                android:textSize="16sp" />
        </FrameLayout>

        <!-- Password field -->
        <TextView
            android:id="@+id/label_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Password"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/box_email" />

        <FrameLayout
            android:id="@+id/box_password"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_password_input"
            app:layout_constraintTop_toBottomOf="@id/label_password">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock"
                app:tint="#9CAF9F" />

            <EditText
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="52dp"
                android:layout_marginEnd="48dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:hint="тЧП тЧП тЧП тЧП тЧП тЧП тЧП тЧП"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#9CAF9F"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/iv_toggle_password"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye"
                app:tint="#9CAF9F" />
        </FrameLayout>

        <!-- Confirm Password field -->
        <TextView
            android:id="@+id/label_confirm_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Confirm Password"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/box_password" />

        <FrameLayout
            android:id="@+id/box_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_password_input"
            app:layout_constraintTop_toBottomOf="@id/label_confirm_password">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock"
                app:tint="#9CAF9F" />

            <EditText
                android:id="@+id/confirmPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="52dp"
                android:layout_marginEnd="48dp"
                android:background="@android:color/transparent"
                android:gravity="start|center_vertical"
                android:hint="тЧП тЧП тЧП тЧП тЧП тЧП тЧП тЧП"
                android:inputType="textPassword"
                android:textColor="#FFFFFF"
                android:textColorHint="#9CAF9F"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/iv_toggle_confirm"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye"
                app:tint="#9CAF9F" />
        </FrameLayout>

        <!-- Terms Checkbox -->
        <CheckBox
            android:id="@+id/terms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:buttonTint="#F4B400"
            android:text="Terms &amp; agreement"
            android:textColor="#9CAF9F"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/box_confirm_password" />

        <!-- Sign Up Button - Honey Gold Gradient -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_btn_signin_gradient"
            app:backgroundTint="@null"
            android:fontFamily="sans-serif-medium"
            android:text="Sign Up"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/terms" />

        <!-- Login Link -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_register">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="#9CAF9F"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_login_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Login"
                android:textColor="#F4B400"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Loading overlay -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="#F4B400"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
