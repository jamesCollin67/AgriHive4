<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F241F">

    <!-- Header Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="AI Disease Scanner"
            android:textColor="#FFFFFF"
            android:textSize="21sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_history"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:src="@drawable/ic_history_box"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#F4B400" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Model Status Badge -->
    <LinearLayout
        android:id="@+id/layout_model_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_status_pill"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_ai"
            app:tint="#F4B400" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:text="MobileNetV2 + BeeClassifier • 7-class"
            android:textColor="#9CAF9F"
            android:textSize="13sp" />

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_green_circle" />
    </LinearLayout>

    <!-- Main Content Container (The Card) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_scanner_card"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="40dp"
        app:layout_constraintTop_toBottomOf="@id/layout_model_info">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_logo_honeycomb"
            app:tint="#F4B400" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-black"
            android:text="Scan for Bee Diseases"
            android:textColor="#FFFFFF"
            android:textSize="24sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:lineSpacingExtra="5dp"
            android:paddingHorizontal="12dp"
            android:text="Take or select a clear photo of your bees or brood frames. The AI will classify against 7 disease categories using real-time neural network inference."
            android:textColor="#9CAF9F"
            android:textSize="15sp" />

        <!-- Dual Buttons Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:paddingHorizontal="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_take_photo"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1.1"
                android:backgroundTint="#F4B400"
                android:fontFamily="sans-serif-black"
                android:text="Take Photo"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_camera"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gallery"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:backgroundTint="#1A3329"
                android:fontFamily="sans-serif-medium"
                android:text="Gallery"
                android:textAllCaps="false"
                android:textColor="#F4B400"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_gallery"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="#F4B400"
                app:strokeColor="#3E4A3E"
                app:strokeWidth="1dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-medium"
            android:text="Detectable Conditions"
            android:textColor="#9CAF9F"
            android:textSize="13sp" />

        <!-- Tags Area -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:text="Healthy"
                    android:textColor="#F4B400"
                    android:textSize="11sp"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:text="Varroa"
                    android:textColor="#F4B400"
                    android:textSize="11sp"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:text="AFB"
                    android:textColor="#F4B400"
                    android:textSize="11sp"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:text="EFB"
                    android:textColor="#F4B400"
                    android:textSize="11sp"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:text="Chalkbrood"
                    android:textColor="#F4B400"
                    android:textSize="11sp"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:text="Sacbrood"
                    android:textColor="#F4B400"
                    android:textSize="11sp"
                    android:maxLines="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_outline"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:text="Nosema"
                    android:textColor="#F4B400"
                    android:textSize="11sp"
                    android:maxLines="1" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
