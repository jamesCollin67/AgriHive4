<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F241F"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <!-- Success Icon -->
        <FrameLayout
            android:id="@+id/layout_success_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="60dp"
            android:background="@drawable/bg_green_circle"
            android:backgroundTint="#1A3329"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_white"
                app:tint="#66BB6A" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_success_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-black"
            android:text="Payment Successful!"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_success_icon" />

        <TextView
            android:id="@+id/tv_success_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Your subscription is now active. Thank you for choosing AgriHive!"
            android:textColor="#9CAF9F"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/tv_success_title" />

        <!-- Receipt Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_receipt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardBackgroundColor="#1A3329"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_success_subtitle"
            app:strokeColor="#2D4A3E"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="#F4B400" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Transaction Receipt"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Details -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reference No." android:textColor="#9CAF9F" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_ref_no" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="AGH-47671142" android:textColor="#FFFFFF" android:textSize="13sp" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Plan" android:textColor="#9CAF9F" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_receipt_plan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="AgriHive Enterprise" android:textColor="#FFFFFF" android:textSize="13sp" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Amount" android:textColor="#9CAF9F" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_receipt_amount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-black" android:text="₱999" android:textColor="#FFFFFF" android:textSize="13sp" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Payment Method" android:textColor="#9CAF9F" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_receipt_method" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="GCash" android:textColor="#FFFFFF" android:textSize="13sp" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date" android:textColor="#9CAF9F" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_receipt_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="March 24, 2026" android:textColor="#FFFFFF" android:textSize="13sp" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Valid Until" android:textColor="#9CAF9F" android:textSize="13sp" />
                    <TextView android:id="@+id/tv_receipt_valid" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-medium" android:text="June 24, 2026" android:textColor="#FFFFFF" android:textSize="13sp" />
                </RelativeLayout>

                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Status" android:textColor="#9CAF9F" android:textSize="13sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:fontFamily="sans-serif-black" android:text="PAID" android:textColor="#66BB6A" android:textSize="13sp" />
                </RelativeLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Confirmation Info -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_confirmation_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#142B33"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/card_receipt"
            app:strokeColor="#1B3A44"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_phone"
                    app:tint="#2196F3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="A confirmation has been sent to your registered GCash account."
                    android:textColor="#9CAF9F"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Bottom Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back_dashboard"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#F4B400"
            android:fontFamily="sans-serif-black"
            android:text="Back to Dashboard"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_home"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/card_confirmation_info"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
