<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="8dp">

    <TextView
        android:id="@+id/tvDiseaseName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Disease Name"
        android:textColor="#9CAF9F"
        android:textSize="13sp"
        app:layout_constraintEnd_toStartOf="@+id/pbConfidence"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/pbConfidence"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:layout_marginHorizontal="16dp"
        android:progress="50"
        android:progressDrawable="@drawable/pb_confidence_bar"
        app:layout_constraintBottom_toBottomOf="@+id/tvDiseaseName"
        app:layout_constraintEnd_toStartOf="@+id/tvPercent"
        app:layout_constraintStart_toEndOf="@+id/tvDiseaseName"
        app:layout_constraintTop_toTopOf="@+id/tvDiseaseName" />

    <TextView
        android:id="@+id/tvPercent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-bold"
        android:text="50%"
        android:textColor="#EF5350"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@+id/tvDiseaseName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvDiseaseName" />

</androidx.constraintlayout.widget.ConstraintLayout>
