<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:background="?attr/selectableItemBackground">

    <!-- Right: Time ago + Time (declared FIRST so layoutText can reference it) -->
    <LinearLayout
        android:id="@+id/layoutTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvTimeAgo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2d ago"
            android:textSize="11sp"
            android:textColor="#888888" />

        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9:37 AM"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Left: Title + Description -->
    <LinearLayout
        android:id="@+id/layoutText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@id/layoutTime"
        android:layout_marginEnd="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hive 1 - Temperature Normalized (35°C)"
            android:textSize="12sp"
            android:textColor="#444444"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="James Collin turned Off cooling fan."
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Bottom Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/layoutText"
        android:layout_marginTop="14dp"
        android:background="#E0E0E0" />

</RelativeLayout>