<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_sucess_dialog"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm report?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:textAlignment="center" />

    <!-- Body Text -->
    <TextView
        android:id="@+id/tvBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="We take reports very seriously. Before sending your report, please make sure it is legit for the incoming fix of the sensors."
        android:textSize="13sp"
        android:textColor="#666666"
        android:textAlignment="center"
        android:layout_marginTop="16dp"
        android:lineSpacingMultiplier="1.3" />

    <!-- Confirm Button -->
    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_gravity="end"
        android:layout_marginTop="24dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:text="Confirm"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:background="@drawable/button_bg"
        app:cornerRadius="24dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</LinearLayout>
