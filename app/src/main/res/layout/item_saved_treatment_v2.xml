<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_stat_card"
    android:padding="16dp">

    <!-- Icon Container -->
    <View
        android:id="@+id/ivIconBg"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_stepper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivThumb"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_warning"
        app:layout_constraintBottom_toBottomOf="@id/ivIconBg"
        app:layout_constraintEnd_toEndOf="@id/ivIconBg"
        app:layout_constraintStart_toStartOf="@id/ivIconBg"
        app:layout_constraintTop_toTopOf="@id/ivIconBg" />

    <!-- Title and Subtitle -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:text="Varroa Mite Infestation"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvScore"
        app:layout_constraintStart_toEndOf="@id/ivIconBg"
        app:layout_constraintTop_toTopOf="@id/ivIconBg" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Hive Alpha · Mar 20, 2026"
        android:textColor="#9CAF9F"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="@id/tvTitle"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Deformed wings, visible mites"
        android:textColor="#9CAF9F"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@id/ivArrow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivIconBg" />

    <!-- Score Circle -->
    <TextView
        android:id="@+id/tvScore"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_circle_outline_red"
        android:gravity="center"
        android:text="42"
        android:textColor="#EF5350"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ivIconBg"
        app:layout_constraintEnd_toStartOf="@id/ivArrow"
        app:layout_constraintTop_toTopOf="@id/ivIconBg" />

    <!-- Arrow (Moved to Bottom Right) -->
    <ImageView
        android:id="@+id/ivArrow"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_chevron_right"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="#9CAF9F" />

</androidx.constraintlayout.widget.ConstraintLayout>
