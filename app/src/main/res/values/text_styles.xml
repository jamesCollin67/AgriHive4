<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- AgriHive Typography: Bold titles, Medium labels, Regular descriptions -->
    
    <!-- HEADINGS - Bold -->
    <style name="TextAppearance.AgriHive.Headline1">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/brown_dark</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    <style name="TextAppearance.AgriHive.Headline2">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/brown_dark</item>
    </style>
    <style name="TextAppearance.AgriHive.Headline3">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/brown_dark</item>
    </style>
    
    <!-- LABELS - Medium -->
    <style name="TextAppearance.AgriHive.Label">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="TextAppearance.AgriHive.LabelLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <!-- BODY - Regular -->
    <style name="TextAppearance.AgriHive.Body">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingMultiplier">1.25</item>
    </style>
    <style name="TextAppearance.AgriHive.BodySmall">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <!-- CAPTION -->
    <style name="TextAppearance.AgriHive.Caption">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>
    
    <!-- VALUE - for sensor readings -->
    <style name="TextAppearance.AgriHive.ValueLarge">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">@color/brown_dark</item>
    </style>
    <style name="TextAppearance.AgriHive.ValueMedium">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>
