<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash Screen Theme -->
    <style name="Theme.AgriHive.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/honey_primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="android:windowBackground">@color/login_bg</item>
        <item name="android:statusBarColor">@color/login_bg</item>
        <item name="android:navigationBarColor">@color/login_bg</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Base application theme - Clean, minimal, premium (Grab/GCash style) -->
    <style name="Theme.AgriHive" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/honey_primary</item>
        <item name="colorPrimaryVariant">@color/honey_primary_dark</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/brown_dark</item>
        <item name="colorSecondaryVariant">@color/brown_medium</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="colorError">@color/status_error</item>
        <item name="colorOnError">@color/text_on_primary</item>
        <item name="android:colorBackground">@color/cream_background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:statusBarColor">@color/background_white</item>
        <item name="android:navigationBarColor">@color/background_white</item>
        <item name="android:windowBackground">@color/cream_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Login screen - Dark forest green theme -->
    <style name="Theme.AgriHive.Login" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/login_accent</item>
        <item name="android:windowBackground">@color/login_bg</item>
        <item name="android:statusBarColor">@color/login_bg</item>
        <item name="android:navigationBarColor">@color/login_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <!-- Fix MaterialCardView default stroke behavior -->
        <item name="materialCardViewStyle">@style/Widget.AgriHive.CardView</item>
    </style>

    <style name="Widget.AgriHive.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardElevation">0dp</item>
    </style>
</resources>