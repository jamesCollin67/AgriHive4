<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions for payment API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Location permissions for weather API -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Notification permission for rain alerts (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Wake lock for background work -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/applogo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/applogo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AgriHive">

        <!-- Splash Screen Activity -->
        <activity
            android:name=".splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AgriHive.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Onboarding - 3 swipeable intro screens -->
        <activity
            android:name=".onboarding.OnboardingActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Landing Activity (Welcome / Auth) -->
        <activity
            android:name=".landing.LandingActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <activity
            android:name=".login.LoginActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive.Login" />

        <activity
            android:name=".register.RegisterActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".forgot.ForgotPasswordActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".forgot.ResetPasswordActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".dashboard.DashboardActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".profile.ProfileActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".addapiary.AddApiaryActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".hivestreams.HiveStreamsActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".editprofile.EditProfileActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".settings.SettingsActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />
        <activity
            android:name=".settings.ChangePasswordActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Device Control Activity -->
        <activity
            android:name=".device.DeviceControlActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Activity Log -->
        <activity
            android:name=".log.ActivityLogActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Sensor Subscription (Pricing) -->
        <activity
            android:name=".sensorsubscription.SensorSubscriptionActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Subscription Checkout -->
        <activity
            android:name=".subscription.SubscriptionActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive">
            <!-- Deep link intent filters for payment return URLs -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- AgriHive return URL for PayPal -->
                <data android:scheme="agrhive" android:host="paypal-return" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- GCash deep link -->
                <data android:scheme="gcash" android:host="payment" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- PayMaya deep link -->
                <data android:scheme="paymaya" android:host="pay" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- BDO deep link -->
                <data android:scheme="bdo" android:host="payment" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- PayPal deep link -->
                <data android:scheme="paypal" android:host="payment" />
            </intent-filter>
        </activity>

        <!-- Send Report -->
        <activity
            android:name=".hivestreams.SendReportActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Capture Issue -->
        <activity
            android:name=".hivestreams.CaptureIssueActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Camera Activity -->
        <activity
            android:name=".camera.CameraActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

        <!-- Notifications Activity -->
        <activity
            android:name=".notification.NotificationActivity"
            android:exported="true"
            android:label="Notifications"
            android:theme="@style/Theme.AgriHive" />

        <!-- Report Sent -->
        <activity
            android:name=".hivestreams.ReportSentActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AgriHive" />

    </application>

</manifest>
